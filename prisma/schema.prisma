generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Cliente {
    id         Int     @id @default(autoincrement())
    nome       String
    telefone   Int     @unique
    email      String  @unique
    cpf        Int     @unique
    cep        Int     @unique
    logradouro String?
    bairro     String?
    localidade String?
    uf         String?
    ativo      Boolean @default(true)

    @@map("cliente")
}

enum Categoria {
    LANCHE
    BEBIDA
    SOBREMESA
    COMBO
}

model Produto {
    id         Int       @id @default(autoincrement())
    nome       String?
    descricao  String
    categoria  Categoria
    preco      Decimal   @db.Decimal(10, 2)
    disponivel Boolean   @default(true)

    @@map("produto")
}

